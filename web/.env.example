# URL-first creator intake (Phase 1: link recognition only — no scraping).
NEXT_PUBLIC_ENABLE_URL_INTAKE=false

# Developer-only: bypass the 5-evaluation trial limit for local testing (default off).
# Requires true; only takes effect in `next dev` unless you intentionally set it in production.
NEXT_PUBLIC_DEV_BYPASS_EVALUATION_LIMIT=false

# OpenAI key — optional.
# Without it, the app returns realistic rule-based mock data so the demo
# always works (creator brief + screenshot extraction both have fallbacks).
OPENAI_API_KEY=

# Model used for the Creator Opportunity Brief (text generation).
OPENAI_MODEL=gpt-4o-mini

# Model used for screenshot signal extraction (vision).
# If unset, falls back to OPENAI_MODEL.
OPENAI_VISION_MODEL=gpt-4o-mini

# Waitlist sync (optional) — localStorage always saves on the client first.
# Generic webhook (Zapier, Make, Airtable automation, Google Apps Script, etc.)
WAITLIST_WEBHOOK_URL=

# Or Supabase REST (no SDK required) — table should match snake_case columns in route.ts
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_WAITLIST_TABLE=waitlist

# Intelligence sync (optional) — evaluations POST here after local save.
# Make.com: Custom webhook → Webhook response = "Immediately" (required).
# Do not rely on "Run once" for production — turn scenario ON instead.
INTELLIGENCE_WEBHOOK_URL=
# Optional Bearer token sent to the webhook receiver
INTELLIGENCE_WEBHOOK_SECRET=

# Supabase Auth + creator memory (optional — OFF for MVP; set CLOUD_MEMORY_ENABLED in lib/supabase/env.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
